<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--Grants permission for foreground services (notifications, media projection).-->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!--Grants permission to display a floating START/STOP button that persists across any View.-->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--Legacy storage permissions, only effective on API 28 and below. On API 29+ scoped storage is used.-->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"
        tools:ignore="ScopedStorage" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!--Grants permission to post notifications.-->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--Grants permission to download and update the application's Firebase Machine Learning OCR.-->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--Grants permission to get the device's IP address for the Remote Log Viewer.-->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!--Enables Battery Optimization coming from the Automation Library.-->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!--Wake lock: held during bot runs so Android doesn't classify the process as 'empty'
        and SIGKILL it under memory pressure. Paired with the FGS declarations below.-->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".MainApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppTheme"
        tools:ignore="AllowBackup"
        android:networkSecurityConfig="@xml/network_security_config"
        android:largeHeap="true">

        <!--Main activity for React Native app with integrated splash screen.-->
        <activity
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:exported="true"
            android:launchMode="singleTask"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:theme="@style/Theme.SplashTheme"
            android:taskAffinity="">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--The Accessibility Service that controls gestures on the screen.-->
        <service
            android:name="com.steve1316.automation_library.utils.MyAccessibilityService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!--The MediaProjection service that controls taking screenshots of the screen.-->
        <service
            android:name="com.steve1316.automation_library.utils.MediaProjectionService"
            android:foregroundServiceType="mediaProjection" />

        <!--Bot Service that automates the specified workflow. dataSync foregroundServiceType
            is required on targetSdk 34+ for any service that calls startForeground(); without
            it, Android can SIGKILL the process under memory pressure (TRIM_EMPTY).-->
        <service
            android:name="com.steve1316.automation_library.utils.BotService"
            android:foregroundServiceType="dataSync" />

        <!--Receiver that will send the "STOP" Intent to MediaProjection Service when the action button on the Notification is tapped.-->
        <receiver
            android:name="com.steve1316.automation_library.utils.StopServiceReceiver"
            android:enabled="true"
            android:process=":remote" />

        <!--Remove ML Kit's auto-init ContentProvider so it doesn't run before
            Application.onCreate. On quick process restarts the stale static MlKitContext
            from the prior process can throw an uncatchable IllegalStateException from the
            provider's attachInfo. MainApplication.onCreate initializes ML Kit explicitly
            in a try/catch instead.-->
        <provider
            android:name="com.google.mlkit.common.internal.MlKitInitProvider"
            android:authorities="${applicationId}.mlkitinitprovider"
            tools:node="remove" />
    </application>

</manifest>