<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--Grants permission for foreground services (notifications, media projection).-->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!--Grants permission to display a floating START/STOP button that persists across any View.-->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--Legacy storage permissions, only effective on API 28 and below. On API 29+ scoped storage is used.-->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"
        tools:ignore="ScopedStorage" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!--Grants permission to post notifications.-->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--Grants permission to download and update the application's Firebase Machine Learning OCR.-->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--Grants permission to get the device's IP address for the Remote Log Viewer.-->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!--Enables Battery Optimization coming from the Automation Library.-->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!--Wake lock: acquired while a bot run is active so the process-bucket classification stays
        stable and Android doesn't decide the process is 'empty' enough to SIGKILL under memory
        pressure. Paired with the FGS declarations below.-->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".MainApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppTheme"
        tools:ignore="AllowBackup"
        android:networkSecurityConfig="@xml/network_security_config"
        android:largeHeap="true">

        <!--Main activity for React Native app with integrated splash screen.-->
        <activity
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:exported="true"
            android:launchMode="singleTask"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:theme="@style/Theme.SplashTheme"
            android:taskAffinity="">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--The Accessibility Service that controls gestures on the screen.-->
        <service
            android:name="com.steve1316.automation_library.utils.MyAccessibilityService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!--The MediaProjection service that controls taking screenshots of the screen.-->
        <service
            android:name="com.steve1316.automation_library.utils.MediaProjectionService"
            android:foregroundServiceType="mediaProjection" />

        <!--Bot Service that automates the specified workflow. dataSync foregroundServiceType is
            required on targetSdk 34+ for any service that calls startForeground(); without it,
            Android can classify the process as 'empty' even while the notification is posted and
            send SIGKILL under moderate memory pressure (observed TRIM_EMPTY kills on MuMu).-->
        <service
            android:name="com.steve1316.automation_library.utils.BotService"
            android:foregroundServiceType="dataSync" />

        <!--Receiver that will send the "STOP" Intent to MediaProjection Service when the action button on the Notification is tapped.-->
        <receiver
            android:name="com.steve1316.automation_library.utils.StopServiceReceiver"
            android:enabled="true"
            android:process=":remote" />

        <!--Remove ML Kit's auto-init ContentProvider. The ML Kit `common` library
            declares its own `MlKitInitProvider` via manifest-merger, which runs
            during process startup BEFORE Application.onCreate. Under certain
            Android process-restart conditions (observed on MuMu after TRIM_EMPTY
            kills) the static MlKitContext from the dying process incarnation
            lingers into the new one, and the provider's onCreate crashes with
            "IllegalStateException: MlKitContext is already initialized" — which
            is uncatchable from app code and kills the new process within ~2s.

            tools:node="remove" strips the provider from the final merged
            manifest. MainApplication.onCreate initializes ML Kit explicitly
            in a try/catch instead, so if the static state is already populated
            from a prior incarnation we quietly reuse it.-->
        <provider
            android:name="com.google.mlkit.common.internal.MlKitInitProvider"
            android:authorities="${applicationId}.mlkitinitprovider"
            tools:node="remove" />
    </application>

</manifest>